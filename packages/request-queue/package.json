  "keywords": [
    "request-queue",
    "rate-limiter",
    "fifo",
    "throttle",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h1s97x/toolkit.git",
    "directory": "packages/request-queue"
  },
  "bugs": {
    "url": "https://github.com/h1s97x/toolkit/issues"
  },
  "homepage": "https://github.com/h1s97x/toolkit/tree/main/packages/request-queue"
