{
  "name": "@h1s97x/errors",
  "version": "0.2.0",
  "description": "Unified error handling for TypeScript applications",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "error",
    "errors",
    "exception",
    "handling",
    "typescript"
  ],
  "author": "h1s97x",
  "license": "MIT",
  "devDependencies": {
    "unbuild": "^2.0.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
