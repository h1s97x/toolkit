{
  "name": "@h1s97x/result",
  "version": "0.1.1",
  "description": "Type-safe Result<T, E> and Option<T> types for functional error handling in TypeScript",
  "author": "h1s97x",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "result",
    "option",
    "either",
    "maybe",
    "error-handling",
    "functional",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h1s97x/toolkit.git",
    "directory": "packages/result"
  },
  "bugs": {
    "url": "https://github.com/h1s97x/toolkit/issues"
  },
  "homepage": "https://github.com/h1s97x/toolkit/tree/main/packages/result",
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
